{
  "name": "animemax-api",
  "version": "1.0.0",
  "description": "Anime streaming REST API powered by Hono. Provides homepage, episodes, servers, and stream URLs.",
  "module": "index.js",
  "main": "index.js",
  "type": "module",
  "keywords": [
    "anime",
    "anime-api",
    "animemax",
    "streaming",
    "hono",
    "bun",
    "hianime",
    "aniwatch"
  ],
  "author": "DksHacker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DksHacker/Animemax-API"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint",
    "lint:fix": "eslint --fix && prettier . --write",
    "dev": "bun --watch index.js",
    "dev:pm2": "pm2 start --interpreter ~/.bun/bin/bun index.js",
    "dev:stop": "pm2 stop all",
    "start": "bun index.js",
    "test": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/swagger-ui": "^0.5.2",
    "@upstash/redis": "^1.35.0",
    "axios": "^1.7.7",
    "cheerio": "^1.0.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.5",
    "hono-rate-limiter": "^0.4.2",
    "node-cache": "^5.1.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/bun": "latest",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.5.3",
    "vitest": "^2.0.0"
  }
}
